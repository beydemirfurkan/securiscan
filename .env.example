# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_api_key_here

# Server Configuration
PORT=3001
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

